{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cnc-vector-lab-website",
  "main": "src/index.js",
  "compatibility_date": "2026-05-19",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "send_email": [
    {
      "name": "EMAIL",
      "destination_address": "contact@cncvectorlab.com"
    }
  ]
}
